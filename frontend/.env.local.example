NEXT_PUBLIC_API_URL=http://localhost:8000/
NEXT_PUBLIC_MFS100_SECURE=false

# Feature flags for configurable biometric & photo capture.
# Set to "false" to disable the corresponding capability at this centre.
NEXT_PUBLIC_ENABLE_FINGERPRINT=true
NEXT_PUBLIC_ENABLE_CAMERA=true
# Set to "true" to make the corresponding capture mandatory for registration.
NEXT_PUBLIC_FINGERPRINT_REQUIRED=false
NEXT_PUBLIC_CAMERA_REQUIRED=false
