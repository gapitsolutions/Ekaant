NEXT_PUBLIC_API_URL=http://localhost:8000/
NEXT_PUBLIC_MFS100_SECURE=false

# Feature flags for configurable biometric & photo capture.  
# Set to "false" to disable the corresponding capability at this centre.
NEXT_PUBLIC_ENABLE_FINGERPRINT=true
NEXT_PUBLIC_ENABLE_CAMERA=true
# Set to "true" to make the corresponding capture mandatory for registration.
NEXT_PUBLIC_FINGERPRINT_REQUIRED=false
NEXT_PUBLIC_CAMERA_REQUIRED=false

# Branding defaults (surface copy + assets)
NEXT_PUBLIC_BRANDING_NAME=Aggarwal Psychiatric & De-Addiction Centre
NEXT_PUBLIC_BRANDING_SHORT_NAME=Aggarwal Psychiatric
NEXT_PUBLIC_BRANDING_SUBTITLE=& De-Addiction Centre
NEXT_PUBLIC_BRANDING_TAGLINE=Comprehensive patient management system
NEXT_PUBLIC_BRANDING_LOGO_PATH=/logo.png
NEXT_PUBLIC_BRANDING_FAVICON_PATH=/logo.png


